<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PracticeWork10M4.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:PracticeWork10M4.Models"
    Title="PracticeWork10M4 - Управління нерухомістю">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.4*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,18">
            <TextBlock
                Text="Управління нерухомістю"
                FontSize="28"
                FontWeight="SemiBold" />

            <TextBlock
                Text="WinUI 3 / MVVM / HTTP-запити до ASP.NET Core Web API"
                FontSize="14"
                Opacity="0.7" />
        </StackPanel>

        <Border
            Grid.Row="1"
            Grid.Column="0"
            Margin="0,0,12,0"
            Padding="16"
            CornerRadius="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                    <Button Content="Оновити" Click="ReloadButton_Click" />

                    <TextBlock
                        Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                        Foreground="Tomato"
                        VerticalAlignment="Center"
                        TextWrapping="Wrap" />
                </StackPanel>

                <ListView
    Grid.Row="1"
    ItemsSource="{x:Bind ViewModel.RealEstateObjects, Mode=OneWay}"
    SelectedItem="{x:Bind ViewModel.SelectedRealEstateObject, Mode=TwoWay}"
    HorizontalContentAlignment="Stretch"
    ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <ListView.Header>
                        <Grid Padding="8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="1.4*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="1.7*" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="130" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="ID" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Назва" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="Адреса" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="Власник" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="4" Text="Ціна" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="5" Text="Статус" FontWeight="SemiBold" />
                        </Grid>
                    </ListView.Header>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:RealEstateObject">
                            <Grid Padding="8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="1.7*" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="130" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                    Text="{x:Bind Id}"
                    VerticalAlignment="Top" />

                                <TextBlock
                    Grid.Column="1"
                    Text="{x:Bind Title}"
                    TextWrapping="WrapWholeWords"
                    VerticalAlignment="Top" />

                                <TextBlock
                    Grid.Column="2"
                    Text="{x:Bind Address}"
                    TextWrapping="WrapWholeWords"
                    VerticalAlignment="Top" />

                                <TextBlock
                    Grid.Column="3"
                    Text="{x:Bind OwnerName}"
                    TextWrapping="WrapWholeWords"
                    VerticalAlignment="Top" />

                                <TextBlock
                    Grid.Column="4"
                    Text="{x:Bind PriceText}"
                    TextWrapping="Wrap"
                    VerticalAlignment="Top" />

                                <TextBlock
                    Grid.Column="5"
                    Text="{x:Bind RentalStatusText}"
                    TextWrapping="WrapWholeWords"
                    VerticalAlignment="Top" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Grid.Column="1"
            Margin="12,0,0,0"
            Padding="16"
            CornerRadius="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

            <StackPanel Spacing="12">

                <TextBlock
                    Text="Форма об'єкта"
                    FontSize="20"
                    FontWeight="SemiBold" />

                <TextBox
                    Header="Назва об'єкта"
                    PlaceholderText="Наприклад: Квартира на Подолі"
                    Text="{x:Bind ViewModel.FormTitle, Mode=TwoWay}" />

                <TextBox
                    Header="Адреса"
                    PlaceholderText="Наприклад: м. Київ, вул. Хрещатик, 10"
                    Text="{x:Bind ViewModel.FormAddress, Mode=TwoWay}" />

                <TextBox
                    Header="Власник"
                    PlaceholderText="Наприклад: Іваненко Іван"
                    Text="{x:Bind ViewModel.FormOwnerName, Mode=TwoWay}" />

                <NumberBox
                    Header="Ціна оренди"
                    PlaceholderText="15000"
                    Value="{x:Bind ViewModel.FormPrice, Mode=TwoWay}" />

                <ComboBox
                    Header="Статус оренди"
                    ItemsSource="{x:Bind ViewModel.Statuses}"
                    SelectedItem="{x:Bind ViewModel.FormRentalStatus, Mode=TwoWay}" />

                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                    <Button
                        Content="Зберегти"
                        Click="SaveButton_Click" />

                    <Button
                        Content="Очистити"
                        Click="ClearButton_Click" />

                    <Button
                        Content="Видалити"
                        Click="DeleteButton_Click" />
                </StackPanel>

                <TextBlock
                    Text="Підказка: щоб редагувати запис, оберіть його у списку, змініть поля праворуч і натисніть «Зберегти»."
                    TextWrapping="Wrap"
                    Opacity="0.7"
                    Margin="0,12,0,0" />

            </StackPanel>
        </Border>
    </Grid>
</Window>